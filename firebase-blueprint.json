{
  "entities": {
    "AdminUser": {
      "title": "AdminUser",
      "description": "Details of admin users authorized to access the console",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin_full", "product_editor", "currency_manager"] },
        "hashedPassword": { "type": "string" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["id", "name", "email", "role", "hashedPassword"]
    },
    "Supplier": {
      "title": "Supplier",
      "description": "Details of suppliers and their contacts",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "contactInfo": { "type": "object" },
        "status": { "type": "string", "enum": ["active", "inactive"] },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["id", "name", "status"]
    },
    "Product": {
      "title": "Product",
      "description": "Details of products sold under management",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "basePrice": { "type": "number" },
        "images": { "type": "array" },
        "supplierIds": { "type": "array" },
        "status": { "type": "string", "enum": ["active", "inactive", "draft"] },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["id", "name", "basePrice", "status"]
    },
    "CurrencyRate": {
      "title": "CurrencyRate",
      "description": "Exchange rates for foreign currencies relative to base",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "currencyCode": { "type": "string" },
        "rateToBase": { "type": "number" },
        "lastUpdated": { "type": "number" },
        "updatedBy": { "type": "string" }
      },
      "required": ["id", "currencyCode", "rateToBase"]
    },
    "Order": {
      "title": "Order",
      "description": "Purchase orders sent from client app",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "productName": { "type": "string" },
        "price": { "type": "string" },
        "unit": { "type": "string" },
        "timestamp": { "type": "string" },
        "status": { "type": "string" },
        "customerName": { "type": "string" },
        "customerPhone": { "type": "string" },
        "notes": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["id", "productName", "price", "customerName", "customerPhone"]
    },
    "SystemAlert": {
      "title": "SystemAlert",
      "description": "Broadcast notifications for customers",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "text": { "type": "string" },
        "time": { "type": "string" },
        "unread": { "type": "boolean" },
        "createdAt": { "type": "number" }
      },
      "required": ["id", "title", "text", "unread", "createdAt"]
    }
  },
  "firestore": {
    "adminUsers/{userId}": {
      "schema": "AdminUser",
      "description": "Authorized administrators"
    },
    "suppliers/{supplierId}": {
      "schema": "Supplier",
      "description": "List of product suppliers"
    },
    "products/{productId}": {
      "schema": "Product",
      "description": "Commodity products catalog"
    },
    "currencyRates/{rateId}": {
      "schema": "CurrencyRate",
      "description": "Daily exchange rates"
    },
    "orders/{orderId}": {
      "schema": "Order",
      "description": "List of customer orders"
    },
    "alerts/{alertId}": {
      "schema": "SystemAlert",
      "description": "Broadcast notifications"
    },
    "config/{configId}": {
      "schema": "object",
      "description": "Configuration items"
    }
  }
}
